{
  "name": "eden-test-reporter-cli",
  "version": "0.1.0",
  "description": "CLI test reporter: pretty live TUI for devs (`run`) + a headless, deterministic, agent-friendly verdict (`check`).",
  "type": "module",
  "bin": {
    "test-reporter": "dist/cli.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "test",
    "reporter",
    "cli",
    "vitest",
    "jest",
    "tui"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "commander": "^12.1.0",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "jest": ">=29"
  },
  "peerDependenciesMeta": {
    "jest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "jest": "^29.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
